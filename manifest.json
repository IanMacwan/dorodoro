{
  "manifest_version": 3,
  "name": "dorodoro",
  "version": "0.2.0",
  "description": "Attention boundary extension",

  "permissions": ["tabs", "storage"],
  "host_permissions": ["*://*.youtube.com/*"],

  "background": {
    "scripts": ["background/index.js"],
    "service_worker": "background/index.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content/index.js"],
      "css": ["styles/overlay.css"]
    }
  ],

  "action": {
    "default_title": "dorodoro",
    "default_popup": "popup/index.html"
  }
}
